{
  "name": "securepass-browser-extension",
  "version": "0.1.0",
  "description": "SecurePass Manager Browser Extension — Chrome, Firefox, Edge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "build:chrome": "cross-env TARGET_BROWSER=chrome npm run build",
    "build:firefox": "cross-env TARGET_BROWSER=firefox npm run build",
    "build:edge": "cross-env TARGET_BROWSER=edge npm run build",
    "build:all": "npx tsx scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist releases",
    "package:chrome": "npx tsx scripts/package.ts chrome",
    "package:firefox": "npx tsx scripts/package.ts firefox",
    "package:edge": "npx tsx scripts/package.ts edge",
    "package:all": "npx tsx scripts/package.ts",
    "release:all": "npm run build:all && npm run package:all",
    "sign:firefox": "npx tsx scripts/sign-firefox.ts",
    "sign:edge": "npx tsx scripts/sign-edge.ts"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/chrome": "^0.0.287",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "archiver": "^7.0.0",
    "cross-env": "^7.0.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "webextension-polyfill": "^0.12.0"
  }
}
