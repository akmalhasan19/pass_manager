{
  "manifest_version": 2,
  "name": "SecurePass Manager",
  "version": "0.1.0",
  "description": "SecurePass Manager — zero-knowledge password manager browser extension",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "nativeMessaging",
    "storage"
  ],
  "background": {
    "scripts": ["background/index.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://www.google.com data:; frame-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'",
  "browser_specific_settings": {
    "gecko": {
      "id": "securepass-manager@securepass-manager.org",
      "strict_min_version": "109.0"
    }
  }
}
